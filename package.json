{
  "name": "zheka-arcade",
  "version": "0.1.0",
  "description": "Arcade shooter game built with Phaser 3 + TypeScript",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "build:single": "tsc --noEmit && SINGLE_FILE=1 vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "typescript": "^5.5.4",
    "vite": "^5.4.2",
    "vite-plugin-singlefile": "^2.3.3"
  },
  "dependencies": {
    "@types/three": "^0.185.0",
    "phaser": "^3.80.1",
    "three": "^0.185.0"
  }
}
